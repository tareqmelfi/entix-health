      `insert into documents (person_id, document_type, title, file_hash, extracted_text, summary, created_by, metadata)
       values ($1, $2, $3, $4, $5, $6, 'hmdb-api', $7)
       returning id, document_type, title, file_hash, summary, created_at`,
