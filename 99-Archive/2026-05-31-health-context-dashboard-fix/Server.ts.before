      file_hash: z.string().max(160).optional(),
      extracted_text: z.string().max(200_000).optional(),
      summary: z.string().max(5000).optional(),
      metadata: z.record(z.string(), z.unknown()).default({})
    })
    .parse(request.body ?? {});
  return withPerson(slug, async (client, person) => {
